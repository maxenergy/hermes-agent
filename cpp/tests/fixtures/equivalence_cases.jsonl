{"name": "simple_greeting", "module": "agent_loop", "input": {"prompt": "Say hello", "model_responses": [{"text": "Hello there!"}]}, "expected_output": {"final_response_contains": "Hello", "tool_calls": 0, "token_range": {"min": 1, "max": 1000}}}
{"name": "tool_call_then_answer", "module": "agent_loop", "input": {"prompt": "Read a file", "tool_seed": {"read_file": {"content": "file data"}}, "model_responses": [{"tool_call": {"name": "read_file", "arguments": {"path": "/tmp/test"}}}, {"text": "The file contains: file data"}]}, "expected_output": {"final_response_contains": "file", "tool_calls": 1}}
{"name": "multi_turn_tool_calls", "module": "agent_loop", "input": {"prompt": "List and read", "tool_seed": {"list_files": {"files": ["a.txt"]}, "read_file": {"content": "hello"}}, "model_responses": [{"tool_call": {"name": "list_files", "arguments": {"dir": "."}}}, {"tool_call": {"name": "read_file", "arguments": {"path": "a.txt"}}}, {"text": "Found a.txt with content hello"}]}, "expected_output": {"final_response_contains": "hello", "tool_calls": 2}}
