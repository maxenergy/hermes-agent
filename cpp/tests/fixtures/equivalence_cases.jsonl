{"name": "prompt_builder_with_skills", "module": "prompt_builder", "input": {"platform": "cli", "skills_index": ["review: review a PR", "security-review: audit changes"]}, "expected_output": {"contains": ["### Available skills", "review:", "security-review:"]}}
